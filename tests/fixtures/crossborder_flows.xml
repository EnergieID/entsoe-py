    <period>
      <timeinterval>
        <start>2026-01-01T02:00Z</start>
        <end>2026-01-01T04:00Z</end>
      </timeinterval>
      <resolution>PT60M</resolution>
      <point><position>1</position><quantity>1400.0</quantity></point>
      <point><position>2</position><quantity>1500.0</quantity></point>
    </period>
  </timeseries>
